# ─── Dev mode: unlocks ALL features without a license key ───────────────────
# Set to "true" during development. NEVER ship this as "true" in production.
VITE_DEV_UNLOCK=true
VITE_RECIPIENT_ADDRESS=address

# ─── WalletConnect v2 ────────────────────────────────────────────────────────
# Get your Project ID from https://cloud.walletconnect.com (free)
# Required for WalletConnect QR login in the subscription popup.
VITE_WC_PROJECT_ID=your_walletconnect_project_id_here

# ─── Lemon Squeezy config ───────────────────────────────────────────────────
# Your LS store slug (from lemonsqueezy.com dashboard)
GH_TOKEN=token