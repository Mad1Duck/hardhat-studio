{
  "name": "hardhat-studio",
  "version": "6.0.7",
  "description": "Professional Hardhat Development Environment",
  "main": "./out/main/index.js",
  "author": "HardhatStudio",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "bun run build && electron-builder",
    "dist:mac": "bun run build && electron-builder --mac",
    "dist:win": "bun run build && electron-builder --win",
    "dist:linux": "bun run build && electron-builder --linux",
    "build:publish": "bun run build && bunx electron-builder --publish always"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@walletconnect/sign-client": "^2.17.0",
    "@xyflow/react": "^12.10.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "ethers": "^6.11.1",
    "keytar": "^7.9.0",
    "mermaid": "^11.12.3",
    "quill": "^2.0.3",
    "radix-ui": "^1.4.3",
    "react-quill": "^2.0.0",
    "react-social-icons": "^6.25.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.0.3",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "lucide-react": "^0.577.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "build": {
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "compression": "normal",
    "generateUpdatesFilesForAllChannels": true,
    "npmRebuild": false,
    "asar": true,
    "appId": "com.hardhatstudio.app",
    "productName": "Hardhat Studio",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "Mad1Duck",
      "repo": "hardhat-studio"
    },
    "icon": "build/icon",
    "protocols": [
      {
        "name": "Hardhat Studio",
        "schemes": [
          "hardhatstudio"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
